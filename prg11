from collections import deque

graph = {0:[1,2], 1:[2], 2:[0,3], 3:[3]}

def bfs(start):
    visited = [False]*4
    q = deque([start])
    visited[start] = True

    while q:
        node = q.popleft()
        print(node, end=" ")
        for i in graph[node]:
            if not visited[i]:
                visited[i] = True
                q.append(i)

bfs(2)
